<robot name = "arm_on_drone" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <link name="world"/>
  <link name="mount_tx_link"/>
  <link name="mount_ty_link"/>
  <link name="mount_tz_link"/>
  <link name="mount_rx_link"/>
  <link name="mount_ry_link"/>

  <joint name="mount_tx" type="prismatic">
    <parent link="world"/>
    <child link="mount_tx_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="1000" velocity="5" lower="-0.85" upper="0.85"/>
  </joint>
  <joint name="mount_ty" type="prismatic">
    <parent link="mount_tx_link"/>
    <child link="mount_ty_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" velocity="5" lower="-0.85" upper="0.85"/>
  </joint>
  <joint name="mount_tz" type="prismatic">
    <parent link="mount_ty_link"/>
    <child link="mount_tz_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000" velocity="5" lower="-0.85" upper="0.85"/>
  </joint>
  <joint name="mount_rx" type="revolute">
    <parent link="mount_tz_link"/>
    <child link="mount_rx_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="1000" velocity="3" lower="-1.0" upper="1.0"/>
  </joint>
  <joint name="mount_ry" type="revolute">
    <parent link="mount_rx_link"/>
    <child link="mount_ry_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" velocity="3" lower="-1.0" upper="1.0"/>
  </joint>
  <joint name="mount_rz" type="revolute">
    <parent link="mount_ry_link"/>
    <child link="drone_mount"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000" velocity="3" lower="-1.0" upper="1.0"/>
  </joint>
  <link name="drone_mount">
